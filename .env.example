# Changes per client
APP_NAME=Laravel
APP_URL=http://localhost
APP_KEY=
APP_ENV=production #or local
APP_DEBUG=false #or true for local development

BUSINESS_ADMIN_EMAIL="root@localhost" #default admin user in migration. Update to your email.

DB_CONNECTION=mysql #or sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=""

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Rarely changes
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# [session]
SESSION_DRIVER=file
#database not recommended if using sqllite, as it locks the entire database for each session write
#SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# [cache]
CACHE_STORE=file
# CACHE_PREFIX=

# [full-page-cache]
RESPONSE_CACHE_DRIVER=file
MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# [rebuild-assets]
REBUILD_ASSETS_LOCALLY=true
# NPM_PATH= (optional override — auto-detected for Herd/nvm; only set if auto-detection fails)

# [cms-updates]
# CMS_RELEASES_API_URL= URL returning {"version":"1.0.1","notes":"..."} — GitHub releases API also supported
# CMS_GIT_BRANCH=main

VITE_APP_NAME="${APP_NAME}"
